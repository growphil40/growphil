.env

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Developer agent files
AGENTS.md
CLAUDE.md

# Git
.git/
.gitignore
